# 3GPP FTP Configuration
FTP_HOST=ftp.3gpp.org

# AWS Configuration
AWS_REGION=us-east-1
RAW_BUCKET=3gpp-data-raw
PROCESSED_BUCKET=3gpp-data-processed

# SageMaker Embedding Endpoint
SAGEMAKER_ENDPOINT_NAME=your-embedding-endpoint

# Aurora Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=knowledge_base_3gpp
DB_USER=postgres
DB_PASSWORD=your-db-password

# LLM (xAI Grok)
XAI_API_KEY=your-xai-api-key-here

# LangSmith Monitoring
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=3gpp-rag-production
